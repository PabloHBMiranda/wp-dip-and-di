{
    "name": "wp-poc/wp-dip-and-di",
    "description": "WordPress DIP + DI Architecture POC — single root autoloader",
    "require": {
        "php": ">=8.1",
        "illuminate/container": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "CoreTheme\\":  "public/wp-content/themes/core-theme/src/",
            "G1News\\":     "public/wp-content/plugins/g1-news/src/",
            "BbcNews\\":    "public/wp-content/plugins/bbc-news/src/",
            "PortalGo\\":   "public/wp-content/plugins/portal-go-news/src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "vendor-dir": "vendor"
    }
}
